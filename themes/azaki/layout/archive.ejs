<% page.__pageType = 'archives'; %>
<main class="archive-page page-enter">
  <section class="archive-hero-card">
    <h1>Blog</h1>
    <p>A place for notes, writeups, and personal research</p>
  </section>

  <section class="archive-boxes hexo-archive-list blog-list-view">
    <% if (page.posts && page.posts.length) { %>
      <% page.posts.each(function(post) { %>
        <%
          const categoryName = post.categories && post.categories.length ? post.categories.data[0].name : 'Blog';
          const cover = post.cover || '/bg/bg.png';
          const desc = post.description || (post.excerpt ? strip_html(post.excerpt).replace(/\s+/g, ' ').trim() : '');
        %>
        <article class="archive-card blog-row-card reveal-item">
          <a href="<%- url_for(post.path) %>">
            <div class="blog-card-cover" aria-hidden="true">
              <img src="<%- cover %>" alt="">
            </div>
            <div class="blog-card-content">
              <h2><%= post.title %></h2>
              <% if (desc) { %>
                <p class="archive-card-desc"><%= desc %></p>
              <% } %>
              <div class="archive-card-meta blog-card-footer">
                <span class="meta-icon meta-date" aria-hidden="true"></span>
                <span><%= date(post.date, 'MMM D, YYYY') %></span>
                <span class="meta-icon meta-folder" aria-hidden="true"></span>
                <span><%= categoryName %></span>
              </div>
              <% if (post.tags && post.tags.length) { %>
                <div class="archive-card-tags">
                  <% post.tags.each(function(tag) { %>
                    <span class="archive-tag"><%= tag.name %></span>
                  <% }) %>
                </div>
              <% } %>
              <p class="archive-card-path"><%= post.display_path || post.original_path || post.source || post.path %></p>
            </div>
          </a>
        </article>
      <% }) %>
    <% } else { %>
      <div class="message-card">
        <h3>No posts yet</h3>
        <p>Add Markdown and images to <code>archives/</code>, then rebuild Hexo.</p>
      </div>
    <% } %>
  </section>

  <% if (page.total && page.total > 1) { %>
    <nav class="archive-pagination" aria-label="Blog pagination">
      <% function archivePageLink(num) { return num === 1 ? '/blog/' : `/blog/page/${num}/`; } %>
      <a class="archive-page-btn <%= page.current === 1 ? 'disabled' : '' %>" href="<%- archivePageLink(Math.max(1, page.current - 1)) %>" aria-label="Previous page">&lt;</a>
      <% for (let i = 1; i <= page.total; i += 1) { %>
        <a class="archive-page-btn <%= i === page.current ? 'active' : '' %>" href="<%- archivePageLink(i) %>"><%= i %></a>
      <% } %>
      <a class="archive-page-btn <%= page.current === page.total ? 'disabled' : '' %>" href="<%- archivePageLink(Math.min(page.total, page.current + 1)) %>" aria-label="Next page">&gt;</a>
    </nav>
  <% } %>
</main>
