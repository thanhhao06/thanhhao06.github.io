<% page.__pageType = 'home'; %>
<main class="landing-page">
  <section class="landing-hero" id="home">
    <div class="landing-grid">
      <div class="landing-copy glass-panel">
        <p class="eyebrow">WELCOME</p>
        <h1>Cyber Security</h1>
        <p class="landing-desc">
          I focus on CTFs, digital forensics, reverse engineering, and blue-team practice in lab environments.
          This site collects my writeups, projects, notes, and the skills I keep sharpening over time.
        </p>

        <div class="landing-tags">
          <a href="/blog/">Blog</a>
          <a href="/project/">Project</a>
          <a href="/skill/">Skill</a>
          <a href="/contact/">Contact</a>
        </div>
      </div>

      <div class="landing-media">
        <div class="video-card">
          <video class="hero-video" autoplay muted loop playsinline poster="/bg/bg.png">
            <source src="/assets/intro.mp4" type="video/mp4">
          </video>
          <div class="video-overlay"></div>
        </div>
        <div class="landing-stats">
          <div class="stat-card">
            <span class="stat-value"><%= site.posts.length %>+</span>
            <span class="stat-label">Blog</span>
          </div>
          <div class="stat-card">
            <span class="stat-value" id="projectCount" data-fallback="2">2+</span>
            <span class="stat-label">Project</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">200+</span>
            <span class="stat-label">Solved</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-preview azaki-about-section" id="about-preview">
    <div class="section-heading">
      <h2>About me</h2>
      <p>Focus on improving not proving</p>
    </div>

    <div class="about-preview-grid">
      <div class="about-preview-card glass-panel">
        <h3>Hello I'm Azaki</h3>
        <p>
          My name is Thanh Hào, and I am a cybersecurity student at the Academy of Cryptography Techniques.
          I am interested in digital forensics, reverse engineering, and SOC analysis. Outside class, I build small labs,
          solve CTF challenges, and turn what I learn into notes that are easy to revisit.
        </p>
      </div>

      <div class="about-avatar-slot">
        <img src="/assets/KMA_logo.png" alt="Academy of Cryptography Techniques logo" class="about-avatar about-kma-logo">
        <p class="about-academy-name"><span>Academy of Cryptography</span><span>Techniques</span></p>
      </div>
    </div>
  </section>
</main>
